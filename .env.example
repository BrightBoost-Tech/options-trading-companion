# ── Supabase (LOCAL) ─────────────────────────────────────────────
# From your screenshot:
# API URL: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# "Publishable key" in the screenshot = the anon key
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# "Secret key" in the screenshot = the service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# (Optional) If you plan to hit Storage from code
# S3 Access Key (from screenshot)
# SUPABASE_S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY_HERE
# S3 Secret Key (from screenshot)
# SUPABASE_S3_SECRET_KEY=YOUR_S3_SECRET_KEY_HERE

# ── App / other keys ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-…              # your Anthropic key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Plaid ────────────────────────────────────────────────────────
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# ── SnapTrade ────────────────────────────────────────────────────
SNAPTRADE_CLIENT_ID=your_snaptrade_client_id
SNAPTRADE_CONSUMER_KEY=your_snaptrade_consumer_key
SNAPTRADE_ENV=production
