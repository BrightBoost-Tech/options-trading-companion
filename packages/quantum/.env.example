# Supabase Configuration (Required)
# Preferred names:
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
SUPABASE_ANON_KEY=<anon_key>
SUPABASE_JWT_SECRET=<jwt_secret>

# Backward Compatibility (Optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Plaid Configuration (Sandbox Mode)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=<your_sandbox_client_id>
PLAID_SECRET=<your_sandbox_secret>

# App Configuration
APP_ENV=development

# SECURITY v3: Required Keys
ENCRYPTION_KEY=<32_byte_url_safe_base64_fernet_key>

# Task Security (Required for Internal Tasks)
TASK_SIGNING_SECRET=<random_secret_string>
TASK_TTL_SECONDS=300
TASK_ALLOWLIST_CIDRS=127.0.0.1/32,10.0.0.0/8

# Dev Authentication Bypass (Localhost Only)
# Set to "1" to enable X-Test-Mode-User header support
ENABLE_DEV_AUTH_BYPASS=0
NEXT_PUBLIC_ENABLE_DEV_AUTH_BYPASS=0

# Polygon.io (Optional for local dev)
POLYGON_API_KEY=<your_polygon_key>

# QCI / Dirac (Optional)
QCI_API_TOKEN=<optional_token>

# AI / Gemini (Optional)
GEMINI_API_KEY=<optional_key>

# Alpaca broker credentials (Required for the nightly audit broker snapshot)
# --------------------------------------------------------------------------
# The nightly audit runner (audit/runner/broker_snapshot.py) reads these from a
# gitignored local .env to produce a READ-ONLY (GET-only) broker-truth snapshot
# for the headless, MCP-absent audit. Windows Task Scheduler launches the runner
# with a bare env, so WITHOUT these in a local .env the snapshot is broker-blind
# (available=false) — F-RUNNER-BROKER-CREDS. Copy this file to `.env` (or
# `.env.local`) and fill in the LIVE account key/secret. Never commit the real
# values (.env / .env.* are gitignored). ALPACA_PAPER=false selects the live
# account; the snapshot only ever issues GETs and places no orders.
ALPACA_API_KEY=<your_alpaca_key_id>
ALPACA_SECRET_KEY=<your_alpaca_secret_key>
ALPACA_PAPER=false
# Optional: point at an explicit creds file instead of the default .env search
# (the VALUE is a path, never a secret).
# AUDIT_BROKER_CREDS_FILE=C:\path\to\otc-broker-creds.env
